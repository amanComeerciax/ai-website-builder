# StackForge AI — Server Environment Variables

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/stackforge?retryWrites=true&w=majority

# Clerk
CLERK_SECRET_KEY=sk_test_xxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxx

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxxx

# Upstash Redis (for BullMQ)
REDIS_URL=redis://default:xxxx@xxxx.upstash.io:6379

# Cloudflare R2
R2_ACCOUNT_ID=xxxx
R2_ACCESS_KEY_ID=xxxx
R2_SECRET_ACCESS_KEY=xxxx
R2_BUCKET_NAME=stackforge-projects

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# App Config
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
